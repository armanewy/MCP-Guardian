{
  "name": "mcp-guardian",
  "version": "0.1.0",
  "description": "Local-first dashboard for MCP server permissions, policies, and audit logs.",
  "type": "module",
  "main": "out/main/index.js",
  "bin": {
    "mcp-guardian-proxy": "out/cli/proxy.js",
    "mcp-guardian-disabled": "out/cli/disabled.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build && node scripts/build-cli.mjs",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.cli.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "proxy": "tsx src/cli/proxy.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.10.1",
    "electron-store": "11.0.2",
    "lucide-react": "1.18.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "3.0.2",
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "42.4.0",
    "electron-vite": "5.0.0",
    "esbuild": "0.25.12",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "7.3.5",
    "vitest": "4.1.9"
  }
}
